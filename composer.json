{
    "name": "erickcomp/laravel-raw-blade-components",
    "type": "package",
    "description": "Provides the possibility to create and use blade components syntax with arbitrary code",
    "keywords": [
        "laravel",
        "framework",
        "blade",
        "component"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.60|^13.10"
    },
    "autoload": {
        "psr-4": {
            "ErickComp\\RawBladeComponents\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ErickComp\\RawBladeComponents\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "ErickComp\\RawBladeComponents\\RawBladeComponentsServiceProvider"
            ],
            "dont-discover": []
        }
    },
    "require-dev": {
        "pestphp/pest": "^3.7",
        "orchestra/testbench": "^9.9",
        "pestphp/pest-plugin-type-coverage": "^3.2"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
